OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o-mini
OPENAI_COMPAT_TIMEOUT_MS=60000
OPENAI_COMPAT_TEMPERATURE=0.2
OPENAI_COMPAT_RESPONSE_FORMAT=true

# Set true to force mock responses even when an API key is configured.
AGENT_MOCK_MODE=false

# Example for an Ollama-compatible local endpoint:
# OPENAI_COMPAT_BASE_URL=http://192.168.0.100:11434/v1
# OPENAI_COMPAT_API_KEY=ollama
# OPENAI_COMPAT_MODEL=gemma4:latest
